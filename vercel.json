{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "vite"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "index.ts"
    }
  },
  "rewrites": [
    {
      "source": "/api(/.*)?",
      "destination": {
        "type": "service",
        "service": "backend"
      }
    },
    { "handle": "filesystem" },
    {
      "source": "/((?!api).*)*",
      "destination": {
        "type": "service",
        "service": "frontend",
        "path": "index.html"
      }
    }
  ]
}
