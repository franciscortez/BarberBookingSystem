# Runtime
NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgres://postgres:replace_with_database_password@127.0.0.1:5432/barber_booking

# Frontend URLs
# Use the frontend device's LAN URL during two-device development.
FRONTEND_URL=http://192.168.1.20:5173
# Comma-separated. Required in production when more than one origin is allowed.
CORS_ALLOWED_ORIGINS=http://192.168.1.20:5173

# Admin JWT
JWT_SECRET=replace_with_a_long_random_secret

# PayMongo test mode (used whenever NODE_ENV is not production)
PAYMONGO_TEST_SECRET_KEY=sk_test_replace_me
PAYMONGO_TEST_PUBLIC_KEY=pk_test_replace_me
PAYMONGO_TEST_WEBHOOK_SECRET=whsk_test_replace_me

# PayMongo live mode (used when NODE_ENV=production)
PAYMONGO_LIVE_SECRET_KEY=sk_live_replace_me
PAYMONGO_LIVE_PUBLIC_KEY=pk_live_replace_me
PAYMONGO_LIVE_WEBHOOK_SECRET=whsk_live_replace_me

# SMTP email
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=replace_with_smtp_username
EMAIL_PASS=replace_with_smtp_password
EMAIL_FROM="Gentlemen's Quarters <bookings@example.com>"

# Optional database pool tuning
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# Optional booking tuning
BOOKING_PENDING_HOLD_MINUTES=15

# Optional rate-limit tuning
RATE_LIMIT_GENERAL_WINDOW_MS=900000
RATE_LIMIT_GENERAL_MAX=300
RATE_LIMIT_CATALOG_WINDOW_MS=900000
RATE_LIMIT_CATALOG_MAX=600
RATE_LIMIT_AVAILABILITY_WINDOW_MS=300000
RATE_LIMIT_AVAILABILITY_MAX=120
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_BOOKING_WINDOW_MS=900000
RATE_LIMIT_BOOKING_MAX=20
